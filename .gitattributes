# Needed for publishing of examples, build worker defaults to core.autocrlf=input.
* text eol=autocrlf

*.mof   text eol=crlf
*.sh    text eol=lf
*.svg   eol=lf

# Ensure any exe files are treated as binary
*.exe binary
*.jpg binary
*.xl* binary
*.pfx binary
*.png binary
*.dll binary
*.so  binary
*.ispac binary

# README.md is generated with LF endings (and its template authored LF) so that
# regeneration is byte-identical to the committed copy under core.autocrlf=true.
README.md          text eol=lf
README.template.md text eol=lf
